{
  "name": "pointly",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run-many -t dev --parallel",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "nx run-many -t typecheck"
  },
  "devDependencies": {
    "nx": "22.7.2",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
