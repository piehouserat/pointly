{
  "name": "pointly",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run-many -t dev --parallel",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "nx run-many -t typecheck",
    "graph": "nx graph",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "nx run-many --target=clean",
    "check-for-updates": "bun x npm-check-updates -ui -ws"
  },
  "devDependencies": {
    "nx": "22.7.5",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
