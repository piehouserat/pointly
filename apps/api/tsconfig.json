{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["@cloudflare/workers-types"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@/*": ["./src/*"],
      "@pointly/auth": ["../../packages/auth/src/index.ts"],
      "@pointly/db": ["../../packages/db/src/index.ts"],
      "@pointly/db/schema": ["../../packages/db/src/schema.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
