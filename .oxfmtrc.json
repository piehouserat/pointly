{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 80,
  "sortTailwindcss": {
    "stylesheet": "packages/ui/src/styles/globals.css",
    "functions": ["cn", "cva"]
  },
  "sortPackageJson": false,
  "overrides": [
    {
      "files": ["**/wrangler.jsonc"],
      "options": {
        "trailingComma": "none"
      }
    }
  ],
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    ".nx/",
    ".output/",
    ".nitro/",
    ".tanstack/",
    ".vinxi/",
    "coverage/",
    "pnpm-lock.yaml",
    ".pnpm-store/",
    ".wrangler/",
    "**/routeTree.gen.ts"
  ]
}
